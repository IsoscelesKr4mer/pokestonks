# Supabase: from Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Server-side only. Never expose to the client.
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Postgres connection strings
# DATABASE_URL: pooled (transaction mode), used at runtime by the app
DATABASE_URL=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
# DATABASE_URL_DIRECT: session pooler (or direct), used only by drizzle-kit for migrations
DATABASE_URL_DIRECT=postgresql://postgres.YOUR_PROJECT:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres

# Pokemon TCG API
POKEMONTCG_API_KEY=

# Public site URL (used in absolute redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cron secret: random string, gates /api/cron/* endpoints. Used in later plans.
CRON_SECRET=
